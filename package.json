{
  "name": "dev-project-manager-v2",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
"scripts": {
  "dev":         "astro dev",
  "build":       "prisma generate && astro build",
  "preview":     "astro preview",
  "db:push":     "dotenv -e .env -- prisma db push",
  "db:generate": "dotenv -e .env -- prisma generate",
  "db:studio":   "dotenv -e .env -- prisma studio",
  "db:seed":     "dotenv -e .env -- tsx prisma/seed.ts",
  "reset-password": "dotenv -e .env -- tsx prisma/reset-password.ts"
},
  "dependencies": {
    "@astrojs/react": "^5.0.7",
    "@astrojs/vercel": "^10.0.8",
    "@neondatabase/serverless": "^0.10.0",
    "@prisma/adapter-neon": "^5.22.0",
    "@prisma/client": "^5.22.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "astro": "^6.4.4",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.2",
    "jose": "^6.2.3",
    "pg": "^8.21.0",
    "prisma": "^5.22.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/pg": "^8.20.0",
    "@types/ws": "^8.18.1",
    "dotenv-cli": "^11.0.0",
    "tsx": "^4.22.4"
  }
}
