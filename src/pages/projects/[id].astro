---
import DashboardLayout from "../../layouts/DashboardLayout.astro"
import { prisma } from "../../lib/prisma"
import { computeProgress, formatDate, PROJECT_TYPE_META } from "../../lib/utils"
import { TaskStatus } from "@prisma/client"
import { ProjectView } from "../../components/islands/ProjectView"

const user   = Astro.locals.user
const { id } = Astro.params

const project = await prisma.project.findFirst({
  where: { id, userId: user.id },
  include: {
    phases: {
      orderBy: { order: "asc" },
      include: {
        milestones: {
          orderBy: { order: "asc" },
          include: { tasks: { orderBy: { order: "asc" } } }
        }
      }
    }
  }
})

if (!project) return Astro.redirect("/")

const allTasks = project.phases.flatMap(p => p.milestones.flatMap(m => m.tasks))
const done     = allTasks.filter(t => t.status === TaskStatus.DONE).length
const blocked  = allTasks.filter(t => t.status === TaskStatus.BLOCKED).length
const total    = allTasks.length
const pct      = computeProgress(done, total)
const typeMeta = PROJECT_TYPE_META[project.type]

const projectJson = JSON.stringify(project.phases)
---

<DashboardLayout title={project.name} user={user}>
  <div class="p-8 max-w-4xl">
    <!-- Back -->
    <a href="/" class="flex items-center gap-1 text-sm text-gray-500 hover:text-gray-300 transition-colors mb-6">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="15 18 9 12 15 6"/>
      </svg>
      Overview
    </a>

    <!-- Project header -->
    <div class="bg-white/[0.03] border border-white/[0.06] rounded-2xl p-6 mb-6">
      <div class="flex items-start justify-between gap-4 mb-4">
        <div class="flex items-center gap-3">
          <div class="w-3 h-12 rounded-full flex-shrink-0" style={`background: ${project.color}`} />
          <div>
            <h1 class="text-xl font-semibold text-white mb-1">{project.name}</h1>
            <div class="flex items-center gap-3 text-sm text-gray-500">
              <span>{typeMeta.icon} {typeMeta.label}</span>
              {project.client && <span>· {project.client}</span>}
              {project.dueDate && <span>· Due {formatDate(project.dueDate)}</span>}
            </div>
          </div>
        </div>
      </div>

      {project.description && (
        <p class="text-sm text-gray-500 mb-4">{project.description}</p>
      )}

      {project.stack.length > 0 && (
        <div class="flex flex-wrap gap-1.5 mb-4">
          {project.stack.map(s => (
            <span class="text-xs px-2 py-0.5 rounded-md bg-white/[0.05] text-gray-400 border border-white/[0.06]">{s}</span>
          ))}
        </div>
      )}

      <!-- Progress -->
      <div class="flex items-center gap-4">
        <div class="flex-1 h-2 rounded-full bg-white/[0.06]">
          <div class="h-2 rounded-full transition-all" style={`width: ${pct}%; background: ${project.color}`} />
        </div>
        <div class="flex gap-4 text-xs text-gray-500 flex-shrink-0">
          <span><span class="text-white font-medium">{pct}%</span> complete</span>
          <span><span class="text-emerald-400 font-medium">{done}</span>/{total} tasks</span>
          {blocked > 0 && <span><span class="text-red-400 font-medium">{blocked}</span> blocked</span>}
        </div>
      </div>
    </div>

    <!-- Interactive project view (React island) -->
    <ProjectView phases={project.phases} client:load />
  </div>
</DashboardLayout>

<script>
  import { ProjectView } from "../../components/islands/ProjectView"
  import { createElement } from "react"
  import { createRoot } from "react-dom/client"

  const container = document.getElementById("project-view")
  if (container) {
    const phases = JSON.parse(container.dataset.phases || "[]")
    createRoot(container).render(createElement(ProjectView, { phases }))
  }
</script>
