---
import DashboardLayout from "../../layouts/DashboardLayout.astro"
import { NewProjectForm } from "../../components/islands/NewProjectForm"
const user = Astro.locals.user
---

<DashboardLayout title="New Project" user={user}>
  <div class="p-8 max-w-xl">
    <a href="/" class="text-sm text-gray-500 hover:text-gray-300 transition-colors mb-4 inline-flex items-center gap-1">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="15 18 9 12 15 6"/>
      </svg>
      Overview
    </a>
    <h1 class="text-2xl font-semibold text-white mt-2 mb-6">New project</h1>
    <NewProjectForm client:load />
  </div>
</DashboardLayout>