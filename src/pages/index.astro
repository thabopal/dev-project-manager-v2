---
import DashboardLayout from "../layouts/DashboardLayout.astro"
import { prisma } from "../lib/prisma"
import { computeProgress, formatDate, PROJECT_TYPE_META } from "../lib/utils"
import { TaskStatus, ProjectStatus } from "@prisma/client"

const user = Astro.locals.user

const projects = await prisma.project.findMany({
  where:   { userId: user.id, status: { not: ProjectStatus.ARCHIVED } },
  include: {
    phases: {
      include: { milestones: { include: { tasks: { select: { status: true } } } } }
    }
  },
  orderBy: { updatedAt: "desc" }
})

const stats = projects.map(p => {
  const allTasks = p.phases.flatMap(ph => ph.milestones.flatMap(m => m.tasks))
  const done     = allTasks.filter(t => t.status === TaskStatus.DONE).length
  const blocked  = allTasks.filter(t => t.status === TaskStatus.BLOCKED).length
  const total    = allTasks.length
  return { ...p, done, blocked, total, pct: computeProgress(done, total) }
})

const totalTasks   = stats.reduce((s, p) => s + p.total, 0)
const totalDone    = stats.reduce((s, p) => s + p.done, 0)
const totalBlocked = stats.reduce((s, p) => s + p.blocked, 0)
const activeCount  = stats.filter(p => p.status === ProjectStatus.ACTIVE).length
const overallPct   = totalTasks > 0 ? computeProgress(totalDone, totalTasks) : 0
---

<DashboardLayout title="Dashboard" user={user}>
  <div style="padding:32px 36px;">

    <!-- Top bar -->
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:28px;">
      <div>
        <h1 style="font-size:26px;font-weight:700;color:#1A1830;letter-spacing:-0.5px;margin-bottom:2px;">Dashboard</h1>
        <p style="font-size:13.5px;color:#9CA3AF;">Welcome back, {user.name?.split(" ")[0] ?? "there"} 👋</p>
      </div>
      <div style="display:flex;align-items:center;gap:8px;">
        <div style="background:white;border:1.5px solid #E5E7EB;border-radius:10px;padding:8px 14px;display:flex;align-items:center;gap:8px;">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#9CA3AF" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
          </svg>
          <span style="font-size:13px;color:#9CA3AF;">Search projects...</span>
        </div>
      </div>
    </div>

    <!-- Overview label -->
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;">
      <h2 style="font-size:16px;font-weight:600;color:#1A1830;">Overview</h2>
      <span style="font-size:12px;color:#9CA3AF;background:white;border:1px solid #E5E7EB;padding:5px 12px;border-radius:8px;">All time</span>
    </div>

    <!-- Stat cards -->
    <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-bottom:28px;">

      <div class="card" style="padding:20px;display:flex;align-items:center;gap:14px;">
        <div class="stat-icon" style="background:#EDE9FE;">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#7C3AED" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/>
          </svg>
        </div>
        <div>
          <div style="font-size:11px;color:#9CA3AF;font-weight:500;margin-bottom:3px;">Active projects</div>
          <div style="font-size:24px;font-weight:700;color:#1A1830;">{activeCount}</div>
        </div>
      </div>

      <div class="card" style="padding:20px;display:flex;align-items:center;gap:14px;">
        <div class="stat-icon" style="background:#FEF3C7;">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#D97706" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/>
          </svg>
        </div>
        <div>
          <div style="font-size:11px;color:#9CA3AF;font-weight:500;margin-bottom:3px;">Total tasks</div>
          <div style="font-size:24px;font-weight:700;color:#1A1830;">{totalTasks}</div>
        </div>
      </div>

      <div class="card" style="padding:20px;display:flex;align-items:center;gap:14px;">
        <div class="stat-icon" style="background:#D1FAE5;">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#059669" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/>
          </svg>
        </div>
        <div>
          <div style="font-size:11px;color:#9CA3AF;font-weight:500;margin-bottom:3px;">Completed</div>
          <div style="font-size:24px;font-weight:700;color:#1A1830;">{totalDone}</div>
        </div>
      </div>

      <div class="card" style={`padding:20px;display:flex;align-items:center;gap:14px;${totalBlocked > 0 ? 'border-color:#FED7AA;' : ''}`}>
        <div class="stat-icon" style={`background:${totalBlocked > 0 ? '#FFEDD5' : '#F3F4F6'};`}>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke={totalBlocked > 0 ? '#EA580C' : '#9CA3AF'} stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/>
          </svg>
        </div>
        <div>
          <div style="font-size:11px;color:#9CA3AF;font-weight:500;margin-bottom:3px;">Blocked</div>
          <div style={`font-size:24px;font-weight:700;color:${totalBlocked > 0 ? '#EA580C' : '#1A1830'};`}>{totalBlocked}</div>
        </div>
      </div>
    </div>

    <!-- Projects section -->
    <div style="display:grid;grid-template-columns:1fr 260px;gap:20px;align-items:start;">

      <!-- Project summary table -->
      <div class="card" style="overflow:hidden;">
        <div style="padding:18px 20px;border-bottom:1px solid #F3F4F6;display:flex;align-items:center;justify-content:space-between;">
          <h3 style="font-size:14px;font-weight:600;color:#1A1830;">Project summary</h3>
          <a href="/projects/new" class="btn-primary" style="display:inline-flex;align-items:center;gap:6px;padding:7px 14px;font-size:12.5px;text-decoration:none;">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
            </svg>
            New project
          </a>
        </div>

        {stats.length === 0 ? (
          <div style="padding:48px;text-align:center;">
            <div style="width:48px;height:48px;border-radius:12px;background:#F3F4F6;display:flex;align-items:center;justify-content:center;margin:0 auto 12px;">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#9CA3AF" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/>
              </svg>
            </div>
            <p style="color:#9CA3AF;font-size:13.5px;margin-bottom:12px;">No projects yet</p>
            <a href="/projects/new" style="font-size:13px;color:#7C3AED;text-decoration:none;font-weight:500;">Create your first project →</a>
          </div>
        ) : (
          <div>
            <!-- Table header -->
            <div style="display:grid;grid-template-columns:1fr 100px 90px 80px;gap:12px;padding:10px 20px;background:#FAFAFA;border-bottom:1px solid #F3F4F6;">
              <span style="font-size:11px;font-weight:600;color:#9CA3AF;text-transform:uppercase;letter-spacing:.05em;">Name</span>
              <span style="font-size:11px;font-weight:600;color:#9CA3AF;text-transform:uppercase;letter-spacing:.05em;">Due date</span>
              <span style="font-size:11px;font-weight:600;color:#9CA3AF;text-transform:uppercase;letter-spacing:.05em;">Status</span>
              <span style="font-size:11px;font-weight:600;color:#9CA3AF;text-transform:uppercase;letter-spacing:.05em;">Progress</span>
            </div>

            {stats.map((p, i) => {
              const statusColor = p.status === "ACTIVE" ? { bg:"#D1FAE5", text:"#065F46" } :
                                  p.status === "ON_HOLD" ? { bg:"#FEF3C7", text:"#92400E" } :
                                  p.status === "COMPLETED" ? { bg:"#EDE9FE", text:"#5B21B6" } :
                                  { bg:"#F3F4F6", text:"#374151" }
              const statusLabel = p.status === "ACTIVE" ? "Active" : p.status === "ON_HOLD" ? "On hold" : p.status === "COMPLETED" ? "Completed" : p.status
              return (
                <a href={`/projects/${p.id}`}
                  style={`display:grid;grid-template-columns:1fr 100px 90px 80px;gap:12px;padding:14px 20px;border-bottom:${i < stats.length-1 ? '1px solid #F9F8FF' : 'none'};text-decoration:none;align-items:center;transition:background 0.15s;`}
                  onmouseover="this.style.background='#FAFAFE'"
                  onmouseout="this.style.background='transparent'">
                  <div style="display:flex;align-items:center;gap:10px;min-width:0;">
                    <div style={`width:8px;height:8px;border-radius:50%;background:${p.color};flex-shrink:0;`}></div>
                    <div style="min-width:0;">
                      <div style="font-size:13.5px;font-weight:500;color:#1A1830;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">{p.name}</div>
                      {p.client && <div style="font-size:11.5px;color:#9CA3AF;">{p.client}</div>}
                    </div>
                  </div>
                  <div style="font-size:12.5px;color:#6B7280;">{p.dueDate ? formatDate(p.dueDate) : "—"}</div>
                  <div>
                    <span class="badge" style={`background:${statusColor.bg};color:${statusColor.text};`}>{statusLabel}</span>
                  </div>
                  <div style="display:flex;align-items:center;gap:6px;">
                    <div style="flex:1;height:5px;border-radius:3px;background:#F3F4F6;">
                      <div style={`height:5px;border-radius:3px;background:${p.pct===100?'#059669':p.color};width:${p.pct}%;`}></div>
                    </div>
                    <span style="font-size:11px;color:#9CA3AF;min-width:24px;">{p.pct}%</span>
                  </div>
                </a>
              )
            })}
          </div>
        )}
      </div>

      <!-- Overall progress card -->
      <div class="card" style="padding:20px;">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;">
          <h3 style="font-size:14px;font-weight:600;color:#1A1830;">Overall progress</h3>
        </div>

        <!-- Radial progress -->
        <div style="display:flex;flex-direction:column;align-items:center;margin-bottom:20px;">
          <div style="position:relative;width:120px;height:120px;">
            <svg width="120" height="120" viewBox="0 0 120 120">
              <circle cx="60" cy="60" r="50" fill="none" stroke="#F3F4F6" stroke-width="12"/>
              <circle cx="60" cy="60" r="50" fill="none" stroke="#7C3AED" stroke-width="12"
                stroke-dasharray={`${overallPct * 3.14} 314`}
                stroke-dashoffset="78.5"
                stroke-linecap="round"
                transform="rotate(-90 60 60)"/>
            </svg>
            <div style="position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;">
              <span style="font-size:22px;font-weight:700;color:#1A1830;">{overallPct}%</span>
              <span style="font-size:11px;color:#9CA3AF;">Complete</span>
            </div>
          </div>
        </div>

        <!-- Mini stats -->
        <div style="display:flex;flex-direction:column;gap:10px;">
          <div style="display:flex;align-items:center;justify-content:space-between;">
            <div style="display:flex;align-items:center;gap:6px;">
              <div style="width:8px;height:8px;border-radius:50%;background:#7C3AED;"></div>
              <span style="font-size:12.5px;color:#6B7280;">Active</span>
            </div>
            <span style="font-size:13px;font-weight:600;color:#1A1830;">{activeCount}</span>
          </div>
          <div style="display:flex;align-items:center;justify-content:space-between;">
            <div style="display:flex;align-items:center;gap:6px;">
              <div style="width:8px;height:8px;border-radius:50%;background:#059669;"></div>
              <span style="font-size:12.5px;color:#6B7280;">Completed tasks</span>
            </div>
            <span style="font-size:13px;font-weight:600;color:#1A1830;">{totalDone}</span>
          </div>
          <div style="display:flex;align-items:center;justify-content:space-between;">
            <div style="display:flex;align-items:center;gap:6px;">
              <div style="width:8px;height:8px;border-radius:50%;background:#EA580C;"></div>
              <span style="font-size:12.5px;color:#6B7280;">Blocked</span>
            </div>
            <span style="font-size:13px;font-weight:600;color:#1A1830;">{totalBlocked}</span>
          </div>
        </div>
      </div>

    </div>
  </div>
</DashboardLayout>
